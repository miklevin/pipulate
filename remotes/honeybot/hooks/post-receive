#!/bin/sh
set -e
# The "Sovereign Build" Hook (Hybrid Late-Stage Edition)

GIT_DIR="/home/mike/git/mikelev.in.git"
WORK_TREE="/home/mike/www/mikelev.in"

echo "🎯 [Hook] Received Push. Deploying..."

# 1. Force Checkout to the Web Root
git --work-tree=$WORK_TREE --git-dir=$GIT_DIR checkout -f main

# 2. Enter the Arena
cd $WORK_TREE
echo "🔨 [Hook] Starting Hybrid Build..."

# 3. The Build Command
# We use 'nix develop' to get Ruby/GCC/Libs, but we manually
# setup the gem environment because --command skips shellHook.
nix develop --command bash -c "
  # ... env setup ...
  
  # --- THE BUILD ---
  echo '🏗️  Jekyll Build...'
  bundle exec jekyll build --future
  
  # --- PUBLISH SOURCE MARKDOWN (CHISEL-STRIKE) ---
  echo '📄 Publishing Source Markdown alongside HTML...'
  
  # Loop through all markdown files in the _posts directory
  for post in _posts/*.md; do
    # Safety check in case the directory is empty
    [ -e \"\$post\" ] || continue

    # Extract the permalink using sed to avoid quote-escaping hell inside bash -c
    # This grabs the line starting with permalink:, removes the key, and strips whitespace and quotes
    PERMALINK=\$(grep -m 1 '^permalink:' \"\$post\" | sed -e 's/^permalink:[[:space:]]*//' -e 's/[\"'\''[:space:]]//g')

    if [ -n \"\$PERMALINK\" ]; then
      # Construct the full target path
      TARGET_DIR=\"_site\$PERMALINK\"
      
      # Create the directory structure quietly
      mkdir -p \"\$TARGET_DIR\"
      
      # Copy the file to its new sovereign home as index.md
      cp \"\$post\" \"\${TARGET_DIR}index.md\"
      echo \"  -> Placed index.md in \$PERMALINK\"
    else
      echo \"  -> Warning: No permalink found in \$post. Skipping.\"
    fi
  done

  # --- PUBLISH ROOT-LEVEL MARKDOWN ---
  echo '📄 Sweeping root directory for standalone Markdown pages...'
  for root_post in *.md; do
    [ -e \"\$root_post\" ] || continue
    
    PERMALINK=\$(grep -m 1 '^permalink:' \"\$root_post\" | sed -e 's/^permalink:[[:space:]]*//' -e 's/[\"'\''[:space:]]//g')

    if [ -n \"\$PERMALINK\" ]; then
      TARGET_DIR=\"_site\$PERMALINK\"
      mkdir -p \"\$TARGET_DIR\"
      cp \"\$root_post\" \"\${TARGET_DIR}index.md\"
      echo \"  -> Placed root index.md in \$PERMALINK\"
    fi
  done
"

# 4. Permissions Fix (Crucial for Nginx)
echo "🔒 [Hook] Fixing Permissions..."
chmod -R 755 $WORK_TREE/_site

echo "✅ [Hook] Deployment Complete. Site is Live."
